# ── HyperVault Environment Variables ──

NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_EXPIRES_IN=24h

# MongoDB (Wallet Service)
MONGODB_URI=mongodb://hypervault:hypervault_dev@localhost:27017/hypervault?authSource=admin

# MySQL (Transaction Service)
DATABASE_URL=mysql://hypervault:hypervault_dev@localhost:3306/hypervault

# Redis (Sessions + Rate Limiting)
REDIS_URL=redis://:hypervault_redis@localhost:6379

# Service Ports
API_GATEWAY_PORT=3000
WALLET_SERVICE_PORT=3001
TRANSACTION_SERVICE_PORT=3002
P2P_SERVICE_PORT=3003

# Internal Service URLs (for Docker networking)
WALLET_SERVICE_URL=http://localhost:3001
TRANSACTION_SERVICE_URL=http://localhost:3002
P2P_SERVICE_URL=http://localhost:3003

# Encryption (AES-256-GCM for private key storage)
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string-0123456789abcdef

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# P2P
P2P_BOOTSTRAP_NODES=
HYPERCORE_STORAGE_PATH=./data/hypercores
